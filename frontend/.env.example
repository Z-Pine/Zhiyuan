# ============================================
# T104: 前端环境变量配置模板
# 高考志愿填报助手 - Flutter Web
# ============================================

# ============================================
# API配置 (必填)
# ============================================
# 后端API基础URL (Railway部署后会获得)
API_BASE_URL=https://zhiyuan-api.railway.app/api

# WebSocket URL (如需要实时功能)
# WS_URL=wss://zhiyuan-api.railway.app/ws

# ============================================
# 应用配置 (必填)
# ============================================
# 应用名称
APP_NAME=志愿填报助手

# 应用版本
APP_VERSION=1.0.0

# 环境类型: development, staging, production
APP_ENV=production

# ============================================
# 功能开关 (可选)
# ============================================
# 是否启用AI对话功能
ENABLE_AI_CHAT=true

# 是否启用导出功能
ENABLE_EXPORT=true

# 是否启用分享功能
ENABLE_SHARE=false

# 是否显示广告
ENABLE_ADS=false

# ============================================
# 第三方服务配置 (可选)
# ============================================
# 百度统计
# BAIDU_TONGJI_ID=your-baidu-tongji-id

# 友盟统计
# UMENG_APP_KEY=your-umeng-app-key

# Sentry错误监控
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# ============================================
# 资源路径配置 (可选)
# ============================================
# 静态资源CDN地址
# CDN_URL=https://cdn.zhiyuan.com

# 图片资源路径
# IMAGE_BASE_URL=https://cdn.zhiyuan.com/images

# 院校Logo路径
# UNIVERSITY_LOGO_URL=https://cdn.zhiyuan.com/logos

# ============================================
# 业务配置 (可选)
# ============================================
# 默认省份
DEFAULT_PROVINCE=湖北

# 默认考试年份
DEFAULT_EXAM_YEAR=2024

# 分页大小
PAGE_SIZE=20

# 请求超时时间 (毫秒)
REQUEST_TIMEOUT=30000

# 最大重试次数
MAX_RETRY_COUNT=3
