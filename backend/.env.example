# ============================================
# T104: 环境变量配置模板
# 高考志愿填报助手 - 后端环境变量
# ============================================

# ============================================
# 数据库配置 (必填)
# ============================================
# Neon PostgreSQL 连接字符串
# 格式: postgresql://username:password@hostname/database?sslmode=require
DATABASE_URL=postgresql://username:password@ep-xxx.us-east-1.aws.neon.tech/zhiyuan_prod?sslmode=require

# 数据库连接池配置
DB_POOL_SIZE=20
DB_CONNECTION_TIMEOUT=10000
DB_IDLE_TIMEOUT=30000

# ============================================
# 服务器配置 (必填)
# ============================================
# 服务器端口
PORT=3000

# 环境类型: development, production
NODE_ENV=production

# API基础路径
API_PREFIX=/api

# ============================================
# JWT认证配置 (必填)
# ============================================
# JWT密钥 (生产环境请使用强密码，至少32位随机字符串)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# JWT过期时间 (访问令牌)
JWT_ACCESS_EXPIRES_IN=15m

# JWT过期时间 (刷新令牌)
JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# 短信服务配置 (必填)
# ============================================
# 阿里云短信服务
SMS_PROVIDER=aliyun
SMS_ACCESS_KEY_ID=your-aliyun-access-key-id
SMS_ACCESS_KEY_SECRET=your-aliyun-access-key-secret
SMS_SIGN_NAME=志愿填报助手
SMS_TEMPLATE_CODE=SMS_12345678

# 腾讯云短信服务 (备选)
# SMS_PROVIDER=tencent
# SMS_SECRET_ID=your-tencent-secret-id
# SMS_SECRET_KEY=your-tencent-secret-key
# SMS_SDK_APP_ID=your-sdk-app-id
# SMS_SIGN_NAME=志愿填报助手
# SMS_TEMPLATE_ID=1234567

# 验证码有效期 (分钟)
SMS_CODE_EXPIRES_IN=5

# 验证码发送间隔 (秒)
SMS_SEND_INTERVAL=60

# ============================================
# 文件存储配置 (可选)
# ============================================
# 阿里云OSS
# OSS_PROVIDER=aliyun
# OSS_ACCESS_KEY_ID=your-access-key-id
# OSS_ACCESS_KEY_SECRET=your-access-key-secret
# OSS_BUCKET=zhiyuan-files
# OSS_REGION=oss-cn-beijing
# OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
# OSS_CDN_DOMAIN=https://files.zhiyuan.com

# 本地存储 (开发环境)
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# ============================================
# 缓存配置 (可选)
# ============================================
# Redis配置
# REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=
# REDIS_DB=0

# 内存缓存 (开发环境使用)
CACHE_TTL=300

# ============================================
# 日志配置 (可选)
# ============================================
# 日志级别: debug, info, warn, error
LOG_LEVEL=info

# 日志文件路径
LOG_FILE=./logs/app.log

# 是否启用请求日志
ENABLE_REQUEST_LOG=true

# ============================================
# CORS配置 (可选)
# ============================================
# 允许的前端域名 (多个用逗号分隔)
CORS_ORIGIN=https://zhiyuan-app.vercel.app,https://www.zhiyuan.com

# 允许的HTTP方法
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS

# 允许的请求头
CORS_HEADERS=Content-Type,Authorization,X-Requested-With

# 是否允许携带凭证
CORS_CREDENTIALS=true

# ============================================
# 限流配置 (可选)
# ============================================
# 每分钟最大请求数
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# 登录接口限流
LOGIN_RATE_LIMIT=5

# 短信发送限流
SMS_RATE_LIMIT=3

# ============================================
# AI服务配置 (可选)
# ============================================
# OpenAI API (用于追问对话)
# OPENAI_API_KEY=sk-your-openai-api-key
# OPENAI_MODEL=gpt-3.5-turbo
# OPENAI_MAX_TOKENS=2000
# OPENAI_TEMPERATURE=0.7

# 百度文心一言 (备选)
# ERNIE_API_KEY=your-ernie-api-key
# ERNIE_SECRET_KEY=your-ernie-secret-key

# ============================================
# 监控告警配置 (可选)
# ============================================
# Sentry错误追踪
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_ENVIRONMENT=production

# ============================================
# 业务配置 (可选)
# ============================================
# 推荐结果最大数量
MAX_RECOMMENDATIONS=50

# 历史记录保留天数
HISTORY_RETENTION_DAYS=365

# 导出文件有效期 (小时)
EXPORT_FILE_EXPIRES_IN=24

# 默认分页大小
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# ============================================
# 安全配置 (可选)
# ============================================
# 密码加密盐值
PASSWORD_SALT_ROUNDS=10

# 会话超时时间 (小时)
SESSION_TIMEOUT=24

# 是否启用HTTPS强制
FORCE_HTTPS=true

# 安全响应头
ENABLE_SECURITY_HEADERS=true
